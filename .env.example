# Vite (browser) — public Firebase web config. Copy from Project settings → General → Your apps, or the npm snippet
# (Same values work for local dev in .env.local; add these to Vercel for production builds.)
VITE_FIREBASE_API_KEY=AIzaSyANtL1d3sG_U9hFbzukpyhk_KpUgQLHM-Q
VITE_FIREBASE_AUTH_DOMAIN=rivlet-early-access-site.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=rivlet-early-access-site
VITE_FIREBASE_STORAGE_BUCKET=rivlet-early-access-site.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=270932357569
VITE_FIREBASE_APP_ID=1:270932357569:web:57e7355a97c923acc7ff40
# Optional — enables Google Analytics in Firebase; from Project settings if enabled
# VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXX

# Server (local Vite dev + Vercel): Firebase *service account* (Admin SDK).
# Download: Firebase Console → Project settings → Service accounts → Generate new private key → JSON file.
#
# Local dev (recommended): save that JSON next to package.json (e.g. .firebase-service-account.json, gitignored) and set:
# FIREBASE_SERVICE_ACCOUNT_PATH=.firebase-service-account.json
# (Relative paths resolve from the repo root — the directory that contains package.json — not process.cwd().)
#
# Or one line in .env (Vercel dashboard): minify the JSON — multi-line JSON in .env does NOT work.
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account",...}
#
# Do NOT paste Node.js here (no require()). Value is JSON only, or use PATH above.
FIREBASE_SERVICE_ACCOUNT_PATH=
FIREBASE_SERVICE_ACCOUNT=

# Resend: https://resend.com — create an API key, then replace the placeholder below with your real key (starts with re_).
# Do not paste the key into source code; use .env.local locally and Vercel env vars in production.
RESEND_API_KEY=re_xxxxxxxxx

# Outgoing mail (after domain verify in Resend)
MAIL_FROM=earlyaccess@therivlet.com

# Inbox for internal "new subscriber" messages
MAIL_NOTIFY_TO=earlyaccess@therivlet.com
